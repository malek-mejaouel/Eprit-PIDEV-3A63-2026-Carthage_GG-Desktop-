<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.carthagegg.controllers.back.CouponsManagementController"
            prefHeight="750.0" prefWidth="1200.0"
            styleClass="root">
    
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #0d0d15; -fx-padding: 20;">
            <Button onAction="#handleBack" styleClass="btn-gold" prefWidth="40">
                <graphic><FontIcon iconLiteral="fas-arrow-left" iconSize="16"/></graphic>
            </Button>
            <Label text="Coupons Management" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 24;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="ADD COUPON" onAction="#handleShowAddForm" styleClass="btn-primary" prefHeight="40">
                <graphic><FontIcon iconLiteral="fas-plus" iconColor="#0a0a0f" iconSize="14"/></graphic>
            </Button>
        </HBox>
    </top>
    
    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="20" left="20" right="20" bottom="20" />
            </padding>
            
            <TableView fx:id="couponsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colCode" text="CODE" prefWidth="150" />
                    <TableColumn fx:id="colDiscount" text="DISCOUNT (%)" prefWidth="150" />
                    <TableColumn fx:id="colExpiry" text="EXPIRY DATE" prefWidth="150" />
                    <TableColumn fx:id="colStatus" text="STATUS" prefWidth="120" />
                    <TableColumn fx:id="colActions" text="ACTIONS" prefWidth="120" />
                </columns>
            </TableView>
        </VBox>
    </center>
    
    <right>
        <VBox fx:id="formPane" visible="false" managed="false" prefWidth="350" spacing="15" styleClass="card">
            <padding>
                <Insets top="30" left="20" right="20" bottom="20" />
            </padding>
            <Label fx:id="formTitle" text="ADD COUPON" styleClass="neon-label" style="-fx-font-size: 18; -fx-font-weight: bold;" />
            
            <Label fx:id="errorLabel" wrapText="true" visible="false" managed="false" 
                   style="-fx-text-fill: #ef4444; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-color: rgba(239, 68, 68, 0.1); -fx-padding: 8; -fx-background-radius: 4; -fx-border-color: rgba(239, 68, 68, 0.3); -fx-border-radius: 4;" 
                   maxWidth="Infinity" />
            
            <VBox spacing="5">
                <Label text="COUPON CODE" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <TextField fx:id="codeField" styleClass="text-field-dark" promptText="e.g. SUMMER20" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="DISCOUNT PERCENTAGE (%)" style="-fx-text-fill: #949499; -fx-font-weight: bold; -fx-font-size: 10;" />
                <TextField fx:id="discountField" styleClass="text-field-dark" promptText="e.g. 20" />
            </VBox>

            <VBox spacing="5">
                <Label text="EXPIRY DATE" style="-fx-text-fill: #949499; -fx-font-weight: bold; -fx-font-size: 10;" />
                <DatePicker fx:id="expiryDatePicker" maxWidth="Infinity" styleClass="text-field-dark" />
            </VBox>
            
            <HBox spacing="10" style="-fx-padding: 20 0 0 0;">
                <Button text="CANCEL" onAction="#handleHideForm" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: #1e1e2e; -fx-text-fill: white;" prefHeight="40" />
                <Button text="SAVE" onAction="#handleSaveCoupon" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="btn-primary" prefHeight="40" />
            </HBox>
        </VBox>
    </right>
    
</BorderPane>
