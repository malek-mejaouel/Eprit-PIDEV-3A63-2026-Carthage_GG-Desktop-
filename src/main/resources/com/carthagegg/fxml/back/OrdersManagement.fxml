<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.carthagegg.controllers.back.OrdersManagementController"
            prefHeight="750.0" prefWidth="1200.0"
            styleClass="root">
    
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #0d0d15; -fx-padding: 20;">
            <Button onAction="#handleBack" styleClass="btn-gold" prefWidth="40">
                <graphic><FontIcon iconLiteral="fas-arrow-left" iconSize="16"/></graphic>
            </Button>
            <Label text="Orders Management" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 24;" />
        </HBox>
    </top>
    
    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="20" left="20" right="20" bottom="20" />
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="REFRESH FROM STRIPE" onAction="#handleRefreshStripe" styleClass="btn-gold">
                    <graphic><FontIcon iconLiteral="fas-sync" iconSize="14"/></graphic>
                </Button>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="EXPORT TO PDF" onAction="#handleExportPDF" styleClass="btn-gold" prefHeight="40">
                    <graphic><FontIcon iconLiteral="fas-file-pdf" iconColor="#0a0a0f" iconSize="14"/></graphic>
                </Button>
            </HBox>
            <TableView fx:id="stripeTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colStripeId" text="Session ID" prefWidth="250" />
                    <TableColumn fx:id="colStripeCustomer" text="Customer" prefWidth="200" />
                    <TableColumn fx:id="colStripeAmount" text="Amount" prefWidth="120" />
                    <TableColumn fx:id="colStripeStatus" text="Status" prefWidth="120" />
                    <TableColumn fx:id="colStripeUrl" text="Receipt/URL" prefWidth="450" />
                </columns>
            </TableView>
        </VBox>
    </center>
    
</BorderPane>
