<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.carthagegg.controllers.back.TournamentsManagementController"
            prefHeight="750.0" prefWidth="1200.0"
            styleClass="root">
    
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #0d0d15; -fx-padding: 20;">
            <Button onAction="#handleBack" styleClass="btn-gold" prefWidth="40">
                <graphic><FontIcon iconLiteral="fas-arrow-left" iconSize="16"/></graphic>
            </Button>
            <Label text="Tournaments Management" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 24;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="ADD NEW TOURNAMENT" onAction="#handleShowAddForm" styleClass="btn-primary" prefHeight="40">
                <graphic><FontIcon iconLiteral="fas-plus" iconColor="#0a0a0f" iconSize="14"/></graphic>
            </Button>
        </HBox>
    </top>
    
    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="20" left="20" right="20" bottom="20" />
            </padding>
            
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search tournaments..." styleClass="text-field-dark" prefWidth="400" />
                <ComboBox fx:id="sortComboBox" promptText="Sort by ID" styleClass="text-field-dark" prefWidth="140" />
            </HBox>
            
            <TableView fx:id="tournamentsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                    <TableColumn fx:id="colName" text="Tournament Name" prefWidth="200" />
                    <TableColumn fx:id="colGame" text="Game" prefWidth="150" />
                    <TableColumn fx:id="colDates" text="Dates" prefWidth="180" />
                    <TableColumn fx:id="colPrize" text="Prize Pool" prefWidth="120" />
                    <TableColumn fx:id="colLocation" text="Location" prefWidth="120" />
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="180" />
                </columns>
            </TableView>
        </VBox>
    </center>
    
    <right>
        <VBox fx:id="formPane" visible="false" managed="false" prefWidth="350" spacing="15" styleClass="card">
            <padding>
                <Insets top="30" left="20" right="20" bottom="20" />
            </padding>
            <Label fx:id="formTitle" text="ADD TOURNAMENT" styleClass="neon-label" style="-fx-font-size: 18; -fx-font-weight: bold;" />
            
            <VBox spacing="5">
                <Label text="TOURNAMENT NAME" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <TextField fx:id="nameField" styleClass="text-field-dark" />
                <Label fx:id="nameErrorLabel" styleClass="error-label" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="GAME" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <ComboBox fx:id="gameComboBox" maxWidth="Infinity" styleClass="text-field-dark" />
                <Label fx:id="gameErrorLabel" styleClass="error-label" />
            </VBox>
            
            <HBox spacing="10">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="START DATE" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                    <DatePicker fx:id="startDatePicker" maxWidth="Infinity" styleClass="text-field-dark" />
                    <Label fx:id="startDateErrorLabel" styleClass="error-label" />
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="END DATE" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                    <DatePicker fx:id="endDatePicker" maxWidth="Infinity" styleClass="text-field-dark" />
                    <Label fx:id="endDateErrorLabel" styleClass="error-label" />
                </VBox>
            </HBox>
            
            <VBox spacing="5">
                <Label text="PRIZE POOL (USD)" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <TextField fx:id="prizeField" styleClass="text-field-dark" />
                <Label fx:id="prizeErrorLabel" styleClass="error-label" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="LOCATION" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <TextField fx:id="locationField" styleClass="text-field-dark" />
                <Label fx:id="locationErrorLabel" styleClass="error-label" />
            </VBox>
            
            <HBox spacing="10">
                <Button text="CANCEL" onAction="#handleHideForm" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: #1e1e2e; -fx-text-fill: white;" prefHeight="40" />
                <Button text="SAVE" onAction="#handleSaveTournament" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="btn-primary" prefHeight="40" />
            </HBox>
        </VBox>
    </right>
    
</BorderPane>
