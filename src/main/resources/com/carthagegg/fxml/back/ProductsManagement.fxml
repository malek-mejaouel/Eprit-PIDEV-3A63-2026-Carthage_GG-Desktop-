<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.carthagegg.controllers.back.ProductsManagementController"
            prefHeight="750.0" prefWidth="1200.0"
            styleClass="root">
    
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #0d0d15; -fx-padding: 20;">
            <Button onAction="#handleBack" styleClass="btn-gold" prefWidth="40">
                <graphic><FontIcon iconLiteral="fas-arrow-left" iconSize="16"/></graphic>
            </Button>
            <Label text="Shop Management" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 24;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="MANAGE COUPONS" onAction="#handleNavCoupons" styleClass="btn-gold" prefHeight="40">
                <graphic><FontIcon iconLiteral="fas-ticket-alt" iconColor="#0a0a0f" iconSize="14"/></graphic>
            </Button>
            <Button text="VIEW ORDERS" onAction="#handleNavOrders" styleClass="btn-gold" prefHeight="40">
                <graphic><FontIcon iconLiteral="fas-shopping-bag" iconColor="#0a0a0f" iconSize="14"/></graphic>
            </Button>
            <Button text="ADD PRODUCT" onAction="#handleShowAddForm" styleClass="btn-primary" prefHeight="40">
                <graphic><FontIcon iconLiteral="fas-plus" iconColor="#0a0a0f" iconSize="14"/></graphic>
            </Button>
        </HBox>
    </top>
    
    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="20" left="20" right="20" bottom="20" />
            </padding>
            
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="Sort By:" style="-fx-text-fill: #949499; -fx-font-size: 13;" />
                <ComboBox fx:id="sortComboBox" promptText="Default (ID ASC)" styleClass="text-field-dark" prefWidth="200" />
            </HBox>

            <TableView fx:id="productsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                    <TableColumn fx:id="colName" text="Name" prefWidth="250" />
                    <TableColumn fx:id="colPrice" text="Price" prefWidth="120" />
                    <TableColumn fx:id="colCategory" text="Category" prefWidth="150" />
                    <TableColumn fx:id="colStock" text="Stock" prefWidth="100" />
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="180" />
                </columns>
            </TableView>
        </VBox>
    </center>
    
    <right>
        <VBox fx:id="formPane" visible="false" managed="false" prefWidth="350" spacing="15" styleClass="card">
            <padding>
                <Insets top="30" left="20" right="20" bottom="20" />
            </padding>
            <Label fx:id="formTitle" text="ADD PRODUCT" styleClass="neon-label" style="-fx-font-size: 18; -fx-font-weight: bold;" />
            
            <Label fx:id="errorLabel" wrapText="true" visible="false" managed="false" 
                   style="-fx-text-fill: #ef4444; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-color: rgba(239, 68, 68, 0.1); -fx-padding: 8; -fx-background-radius: 4; -fx-border-color: rgba(239, 68, 68, 0.3); -fx-border-radius: 4;" 
                   maxWidth="Infinity" />
            
            <VBox spacing="5">
                <Label text="NAME" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <TextField fx:id="nameField" styleClass="text-field-dark" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="PRICE" style="-fx-text-fill: #949499; -fx-font-weight: bold; -fx-font-size: 10;" />
                <TextField fx:id="priceField" styleClass="text-field-dark" text="0.00" />
            </VBox>

            <VBox spacing="5">
                <Label text="SALE PRICE (OPTIONAL)" style="-fx-text-fill: #949499; -fx-font-weight: bold; -fx-font-size: 10;" />
                <TextField fx:id="discountPriceField" styleClass="text-field-dark" promptText="Leave empty if no sale" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="CATEGORY" style="-fx-text-fill: #949499; -fx-font-weight: bold; -fx-font-size: 10;" />
                <ComboBox fx:id="categoryComboBox" maxWidth="Infinity" styleClass="text-field-dark" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="STOCK" style="-fx-text-fill: #949499; -fx-font-weight: bold; -fx-font-size: 10;" />
                <TextField fx:id="stockField" styleClass="text-field-dark" text="0" />
            </VBox>

            <VBox spacing="5" VBox.vgrow="ALWAYS">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="DESCRIPTION" style="-fx-text-fill: #949499; -fx-font-weight: bold; -fx-font-size: 10;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleGenerateAIDescription" style="-fx-background-color: transparent; -fx-text-fill: #ffb800; -fx-font-size: 10; -fx-padding: 0; -fx-cursor: hand;" text="✨ Generate with AI">
                        <graphic><FontIcon iconLiteral="fas-magic" iconSize="10" iconColor="#ffb800"/></graphic>
                    </Button>
                </HBox>
                <TextArea fx:id="descriptionField" styleClass="text-field-dark" prefHeight="100" wrapText="true" promptText="Enter product details..." />
            </VBox>
            
            <VBox spacing="5">
                <Label text="IMAGE" style="-fx-text-fill: #949499; -fx-font-weight: bold; -fx-font-size: 10;" />
                <HBox spacing="10">
                    <TextField fx:id="imageField" editable="false" promptText="Upload an image..." styleClass="text-field-dark" HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleUploadImage" styleClass="btn-gold" prefWidth="40">
                        <graphic><FontIcon iconLiteral="fas-upload" iconSize="14" iconColor="#0a0a0f"/></graphic>
                    </Button>
                </HBox>
            </VBox>
            
            <HBox spacing="10">
                <Button text="CANCEL" onAction="#handleHideForm" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: #1e1e2e; -fx-text-fill: white;" prefHeight="40" />
                <Button text="SAVE" onAction="#handleSaveProduct" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="btn-primary" prefHeight="40" />
            </HBox>
        </VBox>
    </right>
    
</BorderPane>
