<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.carthagegg.controllers.back.TeamsManagementController"
            prefHeight="750.0" prefWidth="1200.0"
            styleClass="root">
    
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #0d0d15; -fx-padding: 20;">
            <Button onAction="#handleBack" styleClass="btn-gold" prefWidth="40">
                <graphic><FontIcon iconLiteral="fas-arrow-left" iconSize="16"/></graphic>
            </Button>
            <Label text="Teams Management" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 24;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="ADD NEW TEAM" onAction="#handleShowAddForm" styleClass="btn-primary" prefHeight="40">
                <graphic><FontIcon iconLiteral="fas-plus" iconColor="#0a0a0f" iconSize="14"/></graphic>
            </Button>
        </HBox>
    </top>
    
    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="20" left="20" right="20" bottom="20" />
            </padding>
            
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search teams..." styleClass="text-field-dark" prefWidth="400" />
                <ComboBox fx:id="sortComboBox" promptText="Sort by ID" styleClass="text-field-dark" prefWidth="140" />
            </HBox>
            
            <TableView fx:id="teamsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                    <TableColumn fx:id="colName" text="Team Name" prefWidth="250" />
                    <TableColumn fx:id="colCaptain" text="Captain" prefWidth="200" />
                    <TableColumn fx:id="colCreationDate" text="Creation Date" prefWidth="180" />
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="180" />
                </columns>
            </TableView>
        </VBox>
    </center>
    
    <right>
        <VBox fx:id="formPane" visible="false" managed="false" prefWidth="350" spacing="15" styleClass="card">
            <padding>
                <Insets top="30" left="20" right="20" bottom="20" />
            </padding>
            <Label fx:id="formTitle" text="ADD TEAM" styleClass="neon-label" style="-fx-font-size: 18; -fx-font-weight: bold;" />
            
            <VBox spacing="5">
                <Label text="TEAM NAME" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <TextField fx:id="nameField" styleClass="text-field-dark" />
                <Label fx:id="nameErrorLabel" styleClass="error-label" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="CAPTAIN (USER)" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <ComboBox fx:id="captainComboBox" maxWidth="Infinity" styleClass="text-field-dark" />
                <Label fx:id="captainErrorLabel" styleClass="error-label" />
            </VBox>

            <VBox spacing="5">
                <Label text="AI LOGO PROMPT (OPTIONAL)" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <TextArea fx:id="aiPromptArea" styleClass="text-field-dark" prefHeight="60" wrapText="true" promptText="e.g. A fierce wolf with neon blue accents..." />
            </VBox>
            
            <VBox spacing="5">
                <Label text="TEAM LOGO" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="logoField" styleClass="text-field-dark" editable="false" HBox.hgrow="ALWAYS" />
                    <Button text="UPLOAD" onAction="#handleBrowseLogo" styleClass="btn-outline" />
                    <Button text="AI" onAction="#handleGenerateLogo" style="-fx-background-color: #3b82f6; -fx-text-fill: white;" />
                </HBox>
                <ImageView fx:id="logoPreview" fitWidth="120" fitHeight="120" preserveRatio="true" smooth="true" />
                <Label fx:id="logoErrorLabel" styleClass="error-label" />
            </VBox>
            
            <HBox spacing="10">
                <Button text="CANCEL" onAction="#handleHideForm" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: #1e1e2e; -fx-text-fill: white;" prefHeight="40" />
                <Button text="SAVE" onAction="#handleSaveTeam" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="btn-primary" prefHeight="40" />
            </HBox>
        </VBox>
    </right>
    
</BorderPane>
