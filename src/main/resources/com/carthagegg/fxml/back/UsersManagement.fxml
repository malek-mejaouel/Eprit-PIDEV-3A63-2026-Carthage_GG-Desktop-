<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.carthagegg.controllers.back.UsersManagementController"
            prefHeight="750.0" prefWidth="1200.0"
            styleClass="root">
    
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #0d0d15; -fx-padding: 20;">
            <Button onAction="#handleBack" styleClass="btn-gold" prefWidth="40">
                <graphic><FontIcon iconLiteral="fas-arrow-left" iconSize="16"/></graphic>
            </Button>
            <Label text="Users Management" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 24;" />
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" promptText="Search by username or email" styleClass="text-field-dark" prefWidth="250" />
            <ComboBox fx:id="roleFilter" promptText="Role" styleClass="text-field-dark" prefWidth="120" />
            <ComboBox fx:id="activeFilter" promptText="Status" styleClass="text-field-dark" prefWidth="120" />
            <ComboBox fx:id="sortOrder" promptText="Sort ID" styleClass="text-field-dark" prefWidth="120" />
        </HBox>
    </top>
    
    <center>
        <TableView fx:id="usersTable" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                <TableColumn fx:id="colUsername" text="Username" prefWidth="150" />
                <TableColumn fx:id="colEmail" text="Email" prefWidth="200" />
                <TableColumn fx:id="colRole" text="Role" prefWidth="150" />
                <TableColumn fx:id="colActive" text="Active" prefWidth="100" />
                <TableColumn fx:id="colActions" text="Actions" prefWidth="200" />
            </columns>
        </TableView>
    </center>

</BorderPane>
