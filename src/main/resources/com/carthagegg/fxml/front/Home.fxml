<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.carthagegg.controllers.front.HomeController"
            prefHeight="750.0" prefWidth="1200.0"
            styleClass="root">
    
    <left>
        <fx:include fx:id="sidebar" source="Sidebar.fxml" />
    </left>
    
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox alignment="TOP_CENTER" spacing="60">
                <padding>
                    <Insets top="80" bottom="80" left="40" right="40" />
                </padding>

                <!-- Badge -->
                <HBox alignment="CENTER">
                    <Label text="Tunisia's Premier Esports Platform" 
                           style="-fx-background-color: rgba(255, 193, 7, 0.1); -fx-text-fill: #FFC107; -fx-padding: 6 16; -fx-background-radius: 20; -fx-border-color: rgba(255, 193, 7, 0.3); -fx-border-radius: 20; -fx-font-size: 13; -fx-font-weight: bold;" />
                </HBox>

                <!-- Hero Section -->
                <VBox alignment="CENTER" spacing="20">
                    <ImageView fx:id="heroLogo" fitHeight="120" fitWidth="120" pickOnBounds="true" preserveRatio="true" />
                    <Label text="Compete. Conquer." styleClass="hero-title" />
                    <Label text="Claim Glory." styleClass="hero-title" />
                    
                    <Label text="Join the ultimate competitive gaming platform inspired by the legendary legacy of Carthage" 
                           styleClass="hero-subtitle" textAlignment="CENTER" wrapText="true" maxWidth="800" />
                </VBox>

                <!-- Action Buttons -->
                <HBox alignment="CENTER" spacing="20">
                    <Button text="Start Competing" onAction="#handleNavTournaments" styleClass="btn-primary" prefWidth="200">
                        <graphic><FontIcon iconLiteral="fas-trophy" iconSize="16"/></graphic>
                    </Button>
                    <Button text="Browse Tournaments" onAction="#handleNavTournaments" styleClass="btn-outline" prefWidth="200" />
                </HBox>

                <!-- Stats Section -->
                <HBox alignment="CENTER" spacing="80">
                    <padding>
                        <Insets top="40" />
                    </padding>
                    
                    <VBox alignment="CENTER" spacing="5">
                        <Label fx:id="statUsers" text="0" styleClass="stat-number" />
                        <Label text="ACTIVE PLAYERS" styleClass="stat-label" />
                    </VBox>
                    
                    <VBox alignment="CENTER" spacing="5">
                        <Label fx:id="statTournaments" text="0" styleClass="stat-number" />
                        <Label text="TOURNAMENTS" styleClass="stat-label" />
                    </VBox>
                    
                    <VBox alignment="CENTER" spacing="5">
                        <Label fx:id="statPrize" text="0 USD" styleClass="stat-number" />
                        <Label text="PRIZE POOL" styleClass="stat-label" />
                    </VBox>
                    
                    <VBox alignment="CENTER" spacing="5">
                        <Label fx:id="statTeams" text="0" styleClass="stat-number" />
                        <Label text="TEAMS" styleClass="stat-label" />
                    </VBox>
                </HBox>

                <!-- Quick Access / Featured (Optional, but good for dynamics) -->
                <VBox spacing="20">
                    <padding><Insets top="40" /></padding>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="LIVE NOW" styleClass="neon-label" style="-fx-font-size: 18;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="View All" onAction="#handleNavStreams" styleClass="btn-outline" style="-fx-padding: 5 15; -fx-font-size: 12;" />
                    </HBox>
                    <FlowPane fx:id="featuredStreams" hgap="20" vgap="20" />
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
    
</BorderPane>
