<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.carthagegg.controllers.front.ShopController"
            prefHeight="750.0" prefWidth="1200.0"
            styleClass="root">
    
    <left>
        <fx:include fx:id="sidebar" source="Sidebar.fxml" />
    </left>
    
    <center>
        <VBox spacing="30">
            <padding>
                <Insets top="40" left="40" right="40" bottom="40" />
            </padding>
            
            <HBox alignment="CENTER_LEFT" spacing="20">
                <VBox>
                    <Label text="Shop" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 32;" />
                    <Label text="Official CarthageGG merchandise and gear" style="-fx-text-fill: #949499;" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <TextField fx:id="searchField" promptText="Search products..." styleClass="text-field-dark" prefWidth="250" prefHeight="40" />
                    <Button onAction="#handleViewCart" styleClass="btn-gold" prefHeight="40" prefWidth="60">
                        <graphic>
                            <StackPane>
                                <FontIcon iconLiteral="fas-shopping-cart" iconSize="20" iconColor="#0a0a0f"/>
                                <Label fx:id="cartCountLabel" text="0"
                                       style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 10; -fx-font-weight: bold; -fx-padding: 2 5; -fx-background-radius: 10;"
                                       StackPane.alignment="TOP_RIGHT">
                                    <StackPane.margin>
                                        <Insets top="-10" right="-10" />
                                    </StackPane.margin>
                                </Label>
                            </StackPane>
                        </graphic>
                    </Button>
                </HBox>
            </HBox>
            
            <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
                <FlowPane fx:id="productsGrid" hgap="20" vgap="20" />
            </ScrollPane>
        </VBox>
    </center>
    
</BorderPane>
