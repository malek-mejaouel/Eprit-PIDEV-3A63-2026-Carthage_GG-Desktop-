<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.carthagegg.controllers.front.EditProfileController"
            prefHeight="750.0" prefWidth="1200.0"
            styleClass="root">
    
    <left>
        <fx:include fx:id="sidebar" source="Sidebar.fxml" />
    </left>
    
    <center>
        <VBox alignment="CENTER" spacing="30">
            <padding>
                <Insets top="40" left="40" right="40" bottom="40" />
            </padding>
            
            <VBox alignment="CENTER" spacing="20" styleClass="card" maxWidth="600">
                <padding><Insets top="40" right="40" bottom="40" left="40" /></padding>
                
                <Label text="EDIT PROFILE" styleClass="neon-label" style="-fx-font-size: 24; -fx-font-weight: bold;" />
                
                <VBox alignment="CENTER" spacing="15">
                    <ImageView fx:id="avatarPreview" fitHeight="120" fitWidth="120" pickOnBounds="true" preserveRatio="true" />
                    <Button text="CHANGE AVATAR" onAction="#handleUploadImage" styleClass="btn-gold" />
                </VBox>
                
                <GridPane hgap="20" vgap="20" alignment="CENTER">
                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2">
                        <Label text="USERNAME" style="-fx-text-fill: #949499; -fx-font-weight: bold; -fx-font-size: 11;" />
                        <TextField fx:id="usernameField" styleClass="text-field-dark" />
                    </VBox>
                    
                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="FIRST NAME" style="-fx-text-fill: #949499; -fx-font-weight: bold; -fx-font-size: 11;" />
                        <TextField fx:id="firstNameField" styleClass="text-field-dark" />
                    </VBox>
                    
                    <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label text="LAST NAME" style="-fx-text-fill: #949499; -fx-font-weight: bold; -fx-font-size: 11;" />
                        <TextField fx:id="lastNameField" styleClass="text-field-dark" />
                    </VBox>
                    
                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                        <Label text="EMAIL (Read-only)" style="-fx-text-fill: #949499; -fx-font-weight: bold; -fx-font-size: 11;" />
                        <TextField fx:id="emailField" editable="false" styleClass="text-field-dark" opacity="0.6" />
                    </VBox>
                </GridPane>
                
                <HBox spacing="15" alignment="CENTER">
                    <Button text="CANCEL" onAction="#handleCancel" prefWidth="150" style="-fx-background-color: #1e1e2e; -fx-text-fill: white;" />
                    <Button text="SAVE CHANGES" onAction="#handleSave" styleClass="btn-primary" prefWidth="150" />
                </HBox>
            </VBox>
        </VBox>
    </center>
    
</BorderPane>
