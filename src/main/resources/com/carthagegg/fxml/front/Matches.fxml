<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.carthagegg.controllers.front.MatchesController"
            prefHeight="750.0" prefWidth="1200.0"
            styleClass="root">
    
    <left>
        <fx:include fx:id="sidebar" source="Sidebar.fxml" />
    </left>
    
    <center>
        <VBox spacing="30">
            <padding>
                <Insets top="40" left="40" right="40" bottom="40" />
            </padding>
            
            <HBox alignment="CENTER_LEFT" spacing="20">
                <VBox>
                    <Label text="Matches" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 32;" />
                    <Label text="Stay updated with the latest match scores" style="-fx-text-fill: #949499;" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
            </HBox>
            
            <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
                <VBox fx:id="matchesContainer" spacing="15">
                    <padding><Insets bottom="20" /></padding>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
    
</BorderPane>
