<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.carthagegg.controllers.front.SnakeGameController"
            prefHeight="750.0" prefWidth="1200.0"
            styleClass="root">
    
    <left>
        <fx:include fx:id="sidebar" source="Sidebar.fxml" />
    </left>
    
    <center>
        <VBox alignment="CENTER" spacing="20" styleClass="card" maxWidth="800" maxHeight="650">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30" />
            </padding>
            
            <HBox alignment="CENTER" spacing="40">
                <VBox alignment="CENTER_LEFT">
                    <Label text="SNAKE GAME" styleClass="neon-label" style="-fx-font-size: 32; -fx-font-weight: bold;" />
                    <Label text="Classic arcade fun while you wait!" style="-fx-text-fill: #949499; -fx-font-size: 14;" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER" style="-fx-background-color: #0a0a0b; -fx-padding: 10 20; -fx-background-radius: 8; -fx-border-color: #232326; -fx-border-width: 1;">
                    <Label text="SCORE" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                    <Label fx:id="scoreLabel" text="0" style="-fx-text-fill: #FFC107; -fx-font-weight: bold; -fx-font-size: 24;" />
                </VBox>
            </HBox>

            <HBox alignment="CENTER" spacing="50">
                <StackPane style="-fx-background-color: #0a0a0b; -fx-border-color: #FFC107; -fx-border-width: 2; -fx-border-radius: 4;">
                    <Canvas fx:id="gameCanvas" width="600" height="400" />
                    <VBox fx:id="gameOverPane" alignment="CENTER" spacing="20" visible="false" style="-fx-background-color: rgba(10, 10, 11, 0.85);">
                        <Label text="GAME OVER" style="-fx-text-fill: #FF4444; -fx-font-weight: bold; -fx-font-size: 48;" />
                        <Button text="Play Again" onAction="#startGame" styleClass="btn-primary" prefWidth="150" />
                    </VBox>
                    <VBox fx:id="startPane" alignment="CENTER" spacing="20" style="-fx-background-color: rgba(10, 10, 11, 0.85);">
                        <Label text="READY?" style="-fx-text-fill: #FFC107; -fx-font-weight: bold; -fx-font-size: 48;" />
                        <Label text="Use Arrow Keys or WASD" style="-fx-text-fill: white; -fx-font-size: 16;" />
                        <Button text="Start Game" onAction="#startGame" styleClass="btn-primary" prefWidth="150" />
                    </VBox>
                </StackPane>

                <!-- On-screen Controls (D-Pad) -->
                <VBox alignment="CENTER" spacing="10">
                    <Button onAction="#moveUp" styleClass="btn-outline" prefWidth="60" prefHeight="60" style="-fx-padding: 0;">
                        <graphic><FontIcon iconLiteral="fas-chevron-up" iconSize="24"/></graphic>
                    </Button>
                    <HBox spacing="10" alignment="CENTER">
                        <Button onAction="#moveLeft" styleClass="btn-outline" prefWidth="60" prefHeight="60" style="-fx-padding: 0;">
                            <graphic><FontIcon iconLiteral="fas-chevron-left" iconSize="24"/></graphic>
                        </Button>
                        <Region prefWidth="60" />
                        <Button onAction="#moveRight" styleClass="btn-outline" prefWidth="60" prefHeight="60" style="-fx-padding: 0;">
                            <graphic><FontIcon iconLiteral="fas-chevron-right" iconSize="24"/></graphic>
                        </Button>
                    </HBox>
                    <Button onAction="#moveDown" styleClass="btn-outline" prefWidth="60" prefHeight="60" style="-fx-padding: 0;">
                        <graphic><FontIcon iconLiteral="fas-chevron-down" iconSize="24"/></graphic>
                    </Button>
                    
                    <VBox alignment="CENTER" spacing="5" style="-fx-padding: 20 0 0 0;">
                        <Label text="CONTROLS" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                        <Label text="ARROWS / WASD" style="-fx-text-fill: white; -fx-font-size: 12;" />
                    </VBox>
                </VBox>
            </HBox>
            
            <HBox alignment="CENTER" spacing="20">
                <Label text="High Score: " style="-fx-text-fill: #949499; -fx-font-size: 14;" />
                <Label fx:id="highScoreLabel" text="0" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;" />
            </HBox>
        </VBox>
    </center>
    
</BorderPane>
