<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.carthagegg.controllers.front.NewsController"
            prefHeight="750.0" prefWidth="1200.0"
            styleClass="root">
    
    <left>
        <fx:include fx:id="sidebar" source="Sidebar.fxml" />
    </left>
    
    <center>
        <VBox spacing="30">
            <padding>
                <Insets top="40" left="40" right="40" bottom="40" />
            </padding>
            
            <HBox alignment="CENTER_LEFT" spacing="20">
                <VBox>
                    <Label text="News" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 32;" />
                    <Label text="Stay informed with the latest updates" style="-fx-text-fill: #949499;" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button fx:id="worldNewsBtn" onAction="#handleFetchWorldNews" styleClass="btn-secondary" prefHeight="40" style="-fx-background-color: #4f46e5; -fx-text-fill: white; -fx-font-weight: bold;">
                        <graphic><FontIcon iconLiteral="fas-globe" iconColor="white" iconSize="14"/></graphic>
                        <text>Worldwide Esports News</text>
                    </Button>
                    <ComboBox fx:id="dateSortCombo" styleClass="text-field-dark" prefWidth="150" prefHeight="40" />
                    <TextField fx:id="searchField" promptText="Search by title..." styleClass="text-field-dark" prefWidth="250" prefHeight="40" />
                    <Button onAction="#handleSearch" styleClass="btn-primary" prefHeight="40">
                        <graphic><FontIcon iconLiteral="fas-search" iconColor="#0a0a0f" iconSize="14"/></graphic>
                    </Button>
                </HBox>
            </HBox>
            
            <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
                <FlowPane fx:id="newsContainer" hgap="25" vgap="25" alignment="TOP_LEFT">
                    <padding>
                        <Insets top="10" left="10" right="10" bottom="10" />
                    </padding>
                </FlowPane>
            </ScrollPane>
        </VBox>
    </center>
    
</BorderPane>
