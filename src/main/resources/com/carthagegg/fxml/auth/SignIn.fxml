<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.carthagegg.controllers.auth.SignInController"
            prefHeight="750.0" prefWidth="1200.0"
            styleClass="root">
    
    <left>
        <VBox alignment="CENTER" prefWidth="600.0" spacing="20" style="-fx-background-color: #0d0d15;">
            <ImageView fx:id="logoImageView" fitHeight="250" fitWidth="250" pickOnBounds="true" preserveRatio="true" />
            <Label text="CarthageGG" styleClass="neon-label" style="-fx-text-fill: #FFC107;">
                <font>
                    <Font name="System Bold" size="48.0" />
                </font>
            </Label>
            <Label text="Tunisia's Premier Esports Platform" style="-fx-text-fill: #949499;">
                <font>
                    <Font size="18.0" />
                </font>
            </Label>
        </VBox>
    </left>
    
    <right>
        <VBox alignment="CENTER" prefWidth="600.0" spacing="30">
            <padding>
                <Insets left="100" right="100" />
            </padding>
            
            <VBox spacing="10">
                <Label text="Sign In" style="-fx-text-fill: white;">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>
                <Label text="Welcome back, champion!" style="-fx-text-fill: #71717a;" />
            </VBox>
            
            <VBox spacing="20">
                <VBox spacing="5">
                    <Label text="EMAIL" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 12;" />
                    <TextField fx:id="emailField" promptText="Enter your email" styleClass="text-field-dark" />
                </VBox>
                
                <VBox spacing="5">
                    <Label text="PASSWORD" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 12;" />
                    <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="text-field-dark" />
                </VBox>
                
                <HBox alignment="CENTER_LEFT">
                    <CheckBox fx:id="rememberMeCheckbox" text="Remember Me" style="-fx-text-fill: #71717a;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Hyperlink text="Forgot Password?" style="-fx-text-fill: #00f0ff;" />
                </HBox>
            </VBox>
            
            <Label fx:id="errorLabel" text="Invalid credentials" visible="false" style="-fx-text-fill: #ef4444;" />
            
            <Button text="Sign In" onAction="#handleSignIn" maxWidth="Infinity" styleClass="btn-primary" prefHeight="45" />

            <HBox alignment="CENTER" spacing="10">
                <Separator HBox.hgrow="ALWAYS" />
                <Label text="OR" style="-fx-text-fill: #71717a;" />
                <Separator HBox.hgrow="ALWAYS" />
            </HBox>

            <Button text="Sign in with Google" onAction="#handleGoogleSignIn" maxWidth="Infinity" styleClass="btn-outline" prefHeight="45">
                <graphic>
                    <FontIcon iconLiteral="fab-google" iconColor="#FFC107" iconSize="16" />
                </graphic>
            </Button>
            
            <HBox alignment="CENTER" spacing="5">
                <Label text="Don't have an account?" style="-fx-text-fill: #71717a;" />
                <Hyperlink text="Sign Up" onAction="#handleGoToSignUp" style="-fx-text-fill: #00f0ff; -fx-font-weight: bold;" />
            </HBox>
        </VBox>
    </right>
    
</BorderPane>
