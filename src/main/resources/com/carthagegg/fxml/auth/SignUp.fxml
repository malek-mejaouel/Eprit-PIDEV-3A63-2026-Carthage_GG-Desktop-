<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.carthagegg.controllers.auth.SignUpController"
           prefHeight="750.0" prefWidth="1200.0"
           styleClass="root">
    
    <VBox alignment="CENTER" maxWidth="500.0" spacing="20" styleClass="card" maxHeight="650">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>
        
        <Label text="CREATE ACCOUNT" styleClass="neon-label">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        
        <GridPane hgap="15" vgap="15">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            
            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="FIRST NAME" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <TextField fx:id="firstNameField" promptText="First Name" styleClass="text-field-dark" />
            </VBox>
            
            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="LAST NAME" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <TextField fx:id="lastNameField" promptText="Last Name" styleClass="text-field-dark" />
            </VBox>
            
            <VBox spacing="5" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                <Label text="USERNAME" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <TextField fx:id="usernameField" promptText="Choose a username" styleClass="text-field-dark" />
            </VBox>
            
            <VBox spacing="5" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="2">
                <Label text="EMAIL ADDRESS" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <TextField fx:id="emailField" promptText="Enter your email" styleClass="text-field-dark" />
            </VBox>
            
            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="3">
                <Label text="PASSWORD" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <PasswordField fx:id="passwordField" promptText="Password" styleClass="text-field-dark" />
            </VBox>
            
            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="3">
                <Label text="CONFIRM PASSWORD" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" styleClass="text-field-dark" />
            </VBox>
            
            <VBox spacing="5" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="4">
                <Label text="SELECT YOUR ROLE" style="-fx-text-fill: #71717a; -fx-font-weight: bold; -fx-font-size: 10;" />
                <ComboBox fx:id="roleComboBox" maxWidth="Infinity" styleClass="text-field-dark" />
            </VBox>
        </GridPane>
        
        <Label fx:id="errorLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 12;" visible="false" managed="false" />
        
        <Button text="CREATE ACCOUNT" onAction="#handleSignUp" maxWidth="Infinity" styleClass="btn-primary" prefHeight="45" />
        
        <HBox alignment="CENTER" spacing="5">
            <Label text="Already have an account?" style="-fx-text-fill: #71717a;" />
            <Hyperlink text="Sign In" onAction="#handleGoToSignIn" style="-fx-text-fill: #00f0ff; -fx-font-weight: bold;" />
        </HBox>
    </VBox>
</StackPane>
